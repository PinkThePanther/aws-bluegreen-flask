{
  "family": "bluegreen-flask",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::973940554982:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "bluegreen-flask",
      "image": "973940554982.dkr.ecr.us-east-1.amazonaws.com/bluegreen-flask:3",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bluegreen-flask",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}